# ============================================
# HiveMind Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# Application
APP_ENV=development
APP_NAME=HiveMind
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Database (PostgreSQL)
# For docker-compose dev setup:
DATABASE_URL=postgresql+asyncpg://hivemind:hivemind_dev@localhost:5432/hivemind

# Slack Integration
# Get these from https://api.slack.com/apps → Your App
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Socket Mode (for local development — no public URL needed)
# Enable Socket Mode in your Slack App settings, then create an App-Level Token
# with the "connections:write" scope
SLACK_APP_TOKEN=xapp-your-app-level-token

# Use Socket Mode for local dev (set to false for production Events API)
SLACK_SOCKET_MODE=true
