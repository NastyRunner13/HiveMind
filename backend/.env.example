# ============================================
# HiveMind Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# All settings are validated at startup — the app fails fast if
# required values are missing.

# ── Application ─────────────────────────────────────────────────
APP_ENV=development                # development | staging | production | testing
APP_NAME=HiveMind
APP_VERSION=0.1.0
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# ── Database (PostgreSQL) ───────────────────────────────────────
# Async driver (asyncpg) for the app, sync driver (psycopg2) for Alembic.
DATABASE_URL=postgresql+asyncpg://hivemind:YOUR_PASSWORD@localhost:5432/hivemind
POSTGRES_PASSWORD=YOUR_PASSWORD    # Used by docker-compose for DB init

# ── Slack Integration ───────────────────────────────────────────
# Get these from https://api.slack.com/apps → Your App
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Socket Mode (for local development — no public URL needed)
# Enable Socket Mode in your Slack App settings, then create an App-Level Token
# with the "connections:write" scope
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SOCKET_MODE=true             # Set to false for production Events API

# -- OIDC API Authentication (Keycloak / Auth0 / any OIDC provider) -----------
# Protected REST endpoints require a bearer token validated via OIDC/JWKS.
# For Keycloak: create a realm and client, then set these values.
OIDC_ISSUER_URL=                   # e.g., http://localhost:8080/realms/hivemind
OIDC_AUDIENCE=                     # Client ID expected in the 'aud' claim
OIDC_DISCOVERY_URL=                # Optional; defaults to {OIDC_ISSUER_URL}/.well-known/openid-configuration

# ── LLM Configuration ──────────────────────────────────────────
# Supported providers: openai, google, anthropic, ollama, openrouter
#
# OpenAI:     LLM_PROVIDER=openai      LLM_MODEL=gpt-4o-mini
# Google:     LLM_PROVIDER=google      LLM_MODEL=gemini-2.0-flash
# Anthropic:  LLM_PROVIDER=anthropic   LLM_MODEL=claude-3-haiku-20240307
# Ollama:     LLM_PROVIDER=ollama      LLM_MODEL=llama3
# OpenRouter: LLM_PROVIDER=openrouter  LLM_MODEL=google/gemma-3-27b-it:free
#
LLM_PROVIDER=openrouter
LLM_MODEL=google/gemma-3-27b-it:free
LLM_API_KEY=                       # REQUIRED (except for Ollama)
LLM_BASE_URL=https://openrouter.ai/api/v1  # Custom API endpoint (OpenRouter, Azure)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── Embedding Configuration ────────────────────────────────────
# local: sentence-transformers (all-MiniLM-L6-v2, 384 dims) — FREE, runs on CPU
# openai: OpenAI API (text-embedding-3-small, 1536 dims) — paid, highest quality
#
# ⚠️  IMPORTANT: EMBEDDING_DIMENSIONS must match SCHEMA_EMBEDDING_DIMENSIONS.
# The Alembic migration (0002) creates vector(384) by default.
# To switch to OpenAI (1536 dims), you MUST:
#   1. Create a new Alembic migration to resize the vector column
#   2. Set SCHEMA_EMBEDDING_DIMENSIONS=1536
#   3. Set EMBEDDING_DIMENSIONS=1536
# The app validates this at startup and refuses to start on mismatch.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_API_KEY=                 # Only needed for openai provider
EMBEDDING_DIMENSIONS=384           # 384 for local, 1536 for openai
SCHEMA_EMBEDDING_DIMENSIONS=384    # Must match the Alembic migration's vector(N)

# ── Redis (Event Bus + Cache) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_MAX_LEN=10000

# ── Daily Digest ───────────────────────────────────────────────
DIGEST_ENABLED=true
DIGEST_HOUR=9                      # 24h format, local time
DIGEST_MINUTE=0
DIGEST_TIMEZONE=UTC
DIGEST_CHANNEL=hivemind-daily      # Slack channel for auto-posting digests

# ── API ────────────────────────────────────────────────────────
API_PREFIX=/api/v1
API_PAGE_SIZE=50
API_MAX_PAGE_SIZE=200
